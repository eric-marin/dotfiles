{
    "layer": "top",
    "spacing": 0,
    "margin": 0,
    "reload_style_on_change": true,
    "fixed-center": false,
    "modules-left": ["clock", "network", "bluetooth", "backlight", "pulseaudio"],
    "modules-center": ["tray"],
    "modules-right": ["cpu", "memory", "temperature", "disk", "battery"],
    "tray": {
        "icon-size": 20,
        "spacing": 5,
    },
    "bluetooth": {
        "format-on": "<span font-family='Symbols Nerd Font Mono'>≤░Γψ</span>",
        "format-off": "<span font-family='Symbols Nerd Font Mono'>≤░Γ▓</span>",
        "format-connected": "<span font-family='Symbols Nerd Font Mono'>≤░Γ▒</span>",
        "tooltip-format-connecte": "{device_alias}",
        "tooltip-format-connected-battery": "{device_alias} ({device_battery_percentage}%)",
        "on-click": "foot bluetuith"
    },
    "network": {
        "format-wifi": "<span font-family='Symbols Nerd Font Mono'>≤░Ψσ</span>",
        "format-disconnected": "<span font-family='Symbols Nerd Font Mono'>≤░Ψς</span>",
        "tooltip-format": "{essid}",
        "on-click": "foot -T nmtui -o pad=0x0 nmtui"
    },
    "pulseaudio": {
        "format": "<span font-family='Symbols Nerd Font Mono'>{icon}</span> {volume}%",
        "format-muted": "<span font-family='Symbols Nerd Font Mono'>≤░ζθ</span> {volume}%",
        "format-icons": {
            "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"],
        },
        "on-click": "foot pulsemixer"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "<span font-family='Symbols Nerd Font Mono'>{icon}</span> {percent}%",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
        "tooltip": false
    },
    "cpu": {
        "interval": 1,
        "format": "<span font-family='Symbols Nerd Font Mono'>ΎΤ╝ </span>{icon0}{icon1}{icon2}{icon3}{icon4}{icon5}{icon6}{icon7}{icon8}{icon9}{icon10}{icon11}{icon12}{icon13}{icon14}{icon15}",
        "format-icons": [
            "<span>έΨΒ</span>",
            "<span>έΨΓ</span>",
            "<span>έΨΔ</span>",
            "<span>έΨΕ</span>",
            "<span>έΨΖ</span>",
            "<span>έΨΗ</span>",
            "<span>έΨΘ</span>",
            "<span>έΨΙ</span>"
        ],
        "on-click": "foot -T btop -o pad=0x0 btop",
    },
    "temperature": {
	"interval": 5,
        "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
        "input-filename": "temp1_input",
        "format": "<span font-family='Symbols Nerd Font Mono'>{icon}</span> {temperatureC}┬░",
        "format-icons": ["ΎΜΜ", "ΎΜΛ", "ΎΜΚ", "ΎΜΙ", "ΎΜΘ"],
        "tooltip": false
    },
    "memory": {
        "interval": 5,
        "format": "<span font-family='Symbols Nerd Font Mono'>≤░αγ</span> {used:0.1f}GiB",
        "tooltip-format": "{used:0.1f}GiB / {total:0.1f}GiB"
    },
    "disk": {
        "format": "<span font-family='Symbols Nerd Font Mono'>≤░ΜΛ</span> {percentage_used}%",
        "tooltip-format": "{used} / {total}"
    },
    "battery": {
	"interval": 5,
        "states": {
            "warning": 25,
        },
        "format": "<span font-family='Symbols Nerd Font Mono'>{icon}</span> {capacity}%",
	"format-charging": "<span font-family='Symbols Nerd Font Mono'>≤░ΓΕ</span>{capacity}%",
        "format-icons": ["≤░ΓΟ","≤░Β║","≤░Β╗","≤░Β╝","≤░Β╜","≤░Β╛","≤░Β┐","≤░ΓΑ","≤░ΓΒ","≤░ΓΓ","≤░Β╣"],
    },
    "clock": {
        "format": "<span font-family='Symbols Nerd Font Mono'>≤░ξΦ</span> {:%H:%M}",
        "tooltip-format": "{:%A, %d %B %Y}"
    }
}

